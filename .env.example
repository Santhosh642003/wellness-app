# Database
POSTGRES_DB=wellness_db
POSTGRES_USER=wellness_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend
DATABASE_URL=postgresql://wellness_user:your_secure_password_here@db:5432/wellness_db
JWT_SECRET=your-very-long-random-secret-key-here
JWT_EXPIRES_IN=7d
PORT=3001

# Frontend
FRONTEND_URL=http://localhost
ADMIN_URL=http://localhost:8080
VITE_API_URL=http://localhost/api

# Google OAuth (get Client ID from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Groq API (get free key from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
