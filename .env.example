# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=wellness_db
POSTGRES_USER=wellness_user
POSTGRES_PASSWORD=your_secure_password_here

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wellness_user:your_secure_password_here@db:5432/wellness_db
JWT_SECRET=your-very-long-random-secret-key-here
JWT_EXPIRES_IN=7d
PORT=3001

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
ADMIN_URL=http://localhost:8080
VITE_API_URL=http://localhost/api
# Used in password-reset emails — set to your public domain in production
APP_URL=http://localhost

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get your Client ID from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Groq API (audio transcription) ───────────────────────────────────────────
# Free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for OTP verification emails and password-reset links.
# Leave SMTP_USER / SMTP_PASS blank in dev — codes are printed to the console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional — defaults to "NJIT Campus Wellness <SMTP_USER>"
SMTP_FROM=

# ── Cloud Storage (S3-compatible) ─────────────────────────────────────────────
# Supports AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO.
# Leave S3_BUCKET blank to use the local ./uploads/ fallback (dev only).
#
# AWS S3:
#   S3_BUCKET=my-bucket
#   S3_REGION=us-east-1
#   S3_ACCESS_KEY=AKIA...
#   S3_SECRET_KEY=...
#   S3_ENDPOINT=               (leave blank for AWS)
#   S3_PUBLIC_URL=             (leave blank to auto-generate virtual-hosted URL)
#
# Cloudflare R2:
#   S3_BUCKET=my-bucket
#   S3_REGION=auto
#   S3_ACCESS_KEY=<R2 Access Key ID>
#   S3_SECRET_KEY=<R2 Secret>
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_PUBLIC_URL=https://pub-<hash>.r2.dev   (or your custom domain)
#
# DigitalOcean Spaces:
#   S3_BUCKET=my-space
#   S3_REGION=nyc3
#   S3_ACCESS_KEY=<Spaces key>
#   S3_SECRET_KEY=<Spaces secret>
#   S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#   S3_PUBLIC_URL=https://my-space.nyc3.cdn.digitaloceanspaces.com
#
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=
