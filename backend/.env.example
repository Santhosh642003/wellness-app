DATABASE_URL=postgresql://wellness_user:wellness_secret@localhost:5432/wellness_db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
GOOGLE_CLIENT_ID=
GROQ_API_KEY=

# Email — leave blank in dev (OTP codes and reset links print to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Public URL used in password-reset email links
APP_URL=http://localhost:5173

# Admin credentials (first-run only — once created, changes here have no effect)
ADMIN_EMAIL=admin@njit.edu
ADMIN_PASSWORD=change-me-before-deploy

# Cloud Storage — leave blank to save files locally in ./uploads/
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=
